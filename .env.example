JWT_AUDIENCE=user
ENV=development
LOG_LEVEL=info
PORT=8018

MIGRATION_DATABASE_URL=
APP_DATABASE_URL=

TRUSTED_PROXY_HOPS=0
AUTHORIZATION_POLICIES_DIR=policies
AUTHORIZATION_POLICY_CACHE_TTL=60
# Optional deploy-time role catalog overlay JSON.
# ROLE_CATALOG_OVERLAY=/app/roles/cdp-overlay.json
MAX_CONTENT_LENGTH=16384
RATELIMIT_STORAGE_URI=memory://
HEALTH_RATE_LIMIT=600 per minute
USER_READ_RATE_LIMIT=60 per minute
USER_WRITE_RATE_LIMIT=30 per minute
WEB_CONCURRENCY=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=30
GUNICORN_KEEPALIVE=5
JWT_JWKS_URI=http://authentication:8014/.well-known/jwks.json
FRONTEND_URL=http://localhost:5173
